APP_NAME="HireMe HR"
APP_VERSION="1.0.0"

# --- AI Interview ---
ALLOWED_MIME_TYPES=["audio/mpeg", "audio/wav", "audio/x-wav", "audio/ogg", "audio/aac", "audio/flac", "audio/mp4"]
MAX_FILE_SIZE_MB=10
WHISPER_MODEL_SIZE="small"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"
LLM_TIMEOUT=300
LLM_MAX_NEW_TOKENS=250
LLM_TEMPERATURE=0.4
LLM_OLLAMA_MODEL="qwen2.5:3b"

# --- ATS ---
FILE_ALLOWED_TYPES=["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document","application/msword"]
FILE_MAX_SIZE=5242880
FILE_MIN_CHARS=50
FILE_MAX_CHARS=50000
FILE_MAX_PAGES=10
DEFAULT_SHORTLIST_LIMIT=150
DEFAULT_RERANK_TOP_N=20
MODELS_CACHE_DIR="~/.cache/huggingface/hub"
MODELS_LOCAL_ONLY=false
GLINER_MODEL="urchade/gliner_medium-v2.1"
EMBEDDER_MODEL="BAAI/bge-m3"
RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
USE_ONNX=false

GLINER_ONNX_DIR=/home/omar-ahmed/onnx_models/gliner
GLINER_ONNX_FILE=model_quantized.onnx
BGE_M3_ONNX_DIR=/home/omar-ahmed/onnx_models/bge-m3-int8
BGE_M3_ONNX_FILE=model_quantized.onnx
RERANKER_ONNX_DIR=/home/omar-ahmed/onnx_models/bge-reranker-int8
RERANKER_ONNX_FILE=model_quantized.onnx

STORAGE_DIR="storage"
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
REDIS_URL=redis://localhost:6379/0

# --- Docker-only (ignored by pydantic-settings) ---
POSTGRES_PASSWORD=omar213ahmed
ONNX_MODELS_DIR=/home/omar-ahmed/onnx_models
